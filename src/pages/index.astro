---
import '../styles/global.css';

const EXAMPLE_ORG_ID = import.meta.env.PUBLIC_EXAMPLE_ORG_ID;
const QRATI_SCRIPT_URL = import.meta.env.PUBLIC_QRATI_SCRIPT_URL;
const QRATI_STYLE_URL = QRATI_SCRIPT_URL?.replace(/\/web\.es\.js$/, '/styles.css');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {QRATI_STYLE_URL && <link rel="stylesheet" href={QRATI_STYLE_URL} />}
    <title>Qrati Connect — Astro Example</title>
  </head>
  <body class="min-h-screen text-neutral-950 antialiased">
    <div class="relative isolate overflow-hidden">
      <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-4 py-10 sm:px-6 lg:px-8">
        <header class="mx-auto max-w-3xl text-center">
          <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-host-200 bg-white/80 px-4 py-1 text-[0.7rem] font-extrabold uppercase tracking-[0.28em] text-host-600 shadow-[0_10px_30px_rgba(255,93,1,0.08)] backdrop-blur">
            Qrati Connect Demo
          </p>
          <h1 class="text-4xl font-bold leading-tight tracking-tight text-neutral-950 sm:text-3xl">
            <span class="text-host-500">Qrati</span> Connect inside an Astro host site
          </h1>
          <p class="mx-auto mt-5 max-w-2xl text-base text-neutral-600">
            This example uses the official Astro setup and keeps the host page visually separate from the embedded widget.
            The watermark belongs to the host shell, while the clean white panel belongs to Qrati Connect.
          </p>
        </header>

        <main class="mt-10 sm:mt-14">
          <section class="relative overflow-hidden rounded-4xl bg-white dark:bg-black p-4 sm:p-6">
              <qrati-connect
                organization-id={EXAMPLE_ORG_ID}
                theme="light"
                router="hash"
              />
          </section>
        </main>
      </div>
    </div>

    <script is:inline define:vars={{ QRATI_SCRIPT_URL }}>
      import(QRATI_SCRIPT_URL);
    </script>
  </body>
</html>
