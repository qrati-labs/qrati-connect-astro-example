---
import '../styles/global.css';

const EXAMPLE_ORG_ID = import.meta.env.PUBLIC_EXAMPLE_ORG_ID;
const QRATI_SCRIPT_URL = import.meta.env.PUBLIC_QRATI_SCRIPT_URL;
const QRATI_STYLE_URL = QRATI_SCRIPT_URL?.replace(/\/web\.es\.js$/, '/styles.css');

const GITHUB_ORG = 'qrati-labs';
const REPO = 'qrati-connect-astro-example';
const repoUrl = `https://github.com/${GITHUB_ORG}/${REPO}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {QRATI_STYLE_URL && <link rel="stylesheet" href={QRATI_STYLE_URL} />}
    <title>Qrati Connect — Astro Example</title>
    <!-- Prevent flash of wrong theme (FOUC guard) -->
    <script is:inline>
      (function(){var s=localStorage.getItem('qc-theme'),p=window.matchMedia('(prefers-color-scheme: dark)').matches;if(s==='dark'||(!s&&p))document.documentElement.classList.add('dark');}());
    </script>
  </head>
  <body class="min-h-screen text-neutral-950 antialiased dark:text-neutral-100">

    <!-- Dark / Light mode toggle (fixed top-right) -->
    <button
      id="theme-toggle"
      type="button"
      aria-label="Toggle dark mode"
      class="fixed top-4 right-4 z-50 flex h-9 w-9 items-center justify-center rounded-full border border-neutral-200 bg-white/90 text-neutral-600 shadow-sm backdrop-blur-sm transition-all duration-200 hover:border-neutral-800 hover:bg-neutral-900 hover:text-white dark:border-neutral-700 dark:bg-neutral-900/90 dark:text-neutral-300 dark:hover:border-white dark:hover:bg-white dark:hover:text-neutral-900"
    >
      <!-- Moon: visible in light mode -->
      <svg id="icon-moon" class="size-[1.05rem]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <!-- Sun: visible in dark mode -->
      <svg id="icon-sun" class="hidden size-[1.05rem]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/>
        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
      </svg>
    </button>

    <div class="relative isolate overflow-hidden">
      <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-4 py-10 sm:px-6 lg:px-8">
        <header class="mx-auto max-w-3xl text-center">
          <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-host-200 bg-white/80 px-4 py-1 text-[0.7rem] font-extrabold uppercase tracking-[0.28em] text-host-600 backdrop-blur">
            Qrati Connect Demo
          </p>
          <h1 class="text-4xl font-bold leading-tight tracking-tight text-neutral-950 dark:text-neutral-50 sm:text-3xl">
            <a href="https://qrati.com" target="_blank" rel="noopener noreferrer"><span class="text-host-500">Qrati</span></a> Connect inside an Astro host site
          </h1>
          <p class="mx-auto mt-5 max-w-3xl text-base text-neutral-600 dark:text-neutral-400">
            This example demonstrates how to integrate <a href="https://qrati.com" target="_blank" rel="noopener noreferrer"><span class="text-host-500 font-semibold">Qrati</span></a> Connect into an Astro application, showcasing the ease of embedding our event engagement platform within your own website or event page.
          </p>

          <!-- Action links -->
          <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
            <a
              href={repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-white/70 px-3 py-1.5 text-xs font-medium text-neutral-600 backdrop-blur transition-all duration-150 hover:border-neutral-800 hover:bg-neutral-950 hover:text-white dark:border-neutral-700 dark:bg-neutral-800/60 dark:text-neutral-300 dark:hover:border-neutral-300 dark:hover:bg-neutral-100 dark:hover:text-neutral-900"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width={24} height={24} viewBox="0 0 24 24" class="size-4"><path fill="currentColor" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"></path></svg>
              View on GitHub
            </a>

            <a
              href={`https://stackblitz.com/github/${GITHUB_ORG}/${REPO}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-white/70 px-3 py-1.5 text-xs font-medium text-neutral-600 backdrop-blur transition-all duration-150 hover:border-[#1389FD] hover:bg-[#1389FD] hover:text-white dark:border-neutral-700 dark:bg-neutral-800/60 dark:text-neutral-300 dark:hover:border-[#1389FD] dark:hover:bg-[#1389FD] dark:hover:text-white"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width={24} height={24} viewBox="0 0 24 24" class="size-4"><path fill="currentColor" d="M10.83 14.38c.09-.18-.09-.36-.28-.36H5.11c-.28 0-.38-.27-.19-.45l10.41-11.5c.19-.18.56 0 .47.27l-2.53 7.37c-.09.18 0 .36.19.36h5.44c.28 0 .38.27.19.45L8.68 21.93c-.19.18-.56 0-.47-.27l2.63-7.28Z"></path></svg>
              Open in StackBlitz
            </a>

            <a
              href={`https://codesandbox.io/s/github/${GITHUB_ORG}/${REPO}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-white/70 px-3 py-1.5 text-xs font-medium text-neutral-600 backdrop-blur transition-all duration-150 hover:border-neutral-800 hover:bg-neutral-950 hover:text-white dark:border-neutral-700 dark:bg-neutral-800/60 dark:text-neutral-300 dark:hover:border-neutral-300 dark:hover:bg-neutral-100 dark:hover:text-neutral-900"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width={24} height={24} viewBox="0 0 24 24" class="size-3"><path fill="currentColor" d="M0 24h24V0H0v2.455h21.546v19.09H2.454V0H0Z"></path></svg>
              Open in CodeSandbox
            </a>

            <a
              href={`https://vscode.dev/github/${GITHUB_ORG}/${REPO}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-white/70 px-3 py-1.5 text-xs font-medium text-neutral-600 backdrop-blur transition-all duration-150 hover:border-[#007ACC] hover:bg-[#007ACC] hover:text-white dark:border-neutral-700 dark:bg-neutral-800/60 dark:text-neutral-300 dark:hover:border-[#007ACC] dark:hover:bg-[#007ACC] dark:hover:text-white"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width={16} height={16} viewBox="0 0 16 16" class="size-4"><path fill="currentColor" d="M10.863 13.919a.8.8 0 0 1-.644.025a.8.8 0 0 1-.279-.183L4.816 9.063l-2.232 1.703a.54.54 0 0 1-.691-.031l-.716-.655a.546.546 0 0 1 0-.805L3.112 7.5L1.177 5.725a.546.546 0 0 1 0-.805l.716-.655a.54.54 0 0 1 .691-.031l2.232 1.703L9.94 1.239a.805.805 0 0 1 .923-.159l2.677 1.295c.281.136.46.422.46.736V8h-3.248V4.534L6.864 7.5l3.888 2.966V8H14v3.889c0 .314-.179.6-.46.736z"></path></svg>
              Open in VS Code
            </a>
          </div>
        </header>

        <main class="mt-3 sm:mt-9 relative overflow-hidden rounded-xl border-2 border-[#ff4800]/50">
          <section class="p-3 sm:p-6 bg-white dark:bg-black rounded-lg">
            <qrati-connect
              id="qrati-widget"
              organization-id={EXAMPLE_ORG_ID}
              theme="light"
              router="hash"
            />
          </section>
        </main>

        <!-- Footer -->
        <footer class="mt-6 pb-2">
          <div class="flex flex-col items-center gap-6 sm:flex-row sm:items-start sm:justify-between">
            <div class="flex gap-3 items-center">
              <img src="https://assets.qrati.com/images/qrati-connect-logo-square.png" alt="Qrati Connect Logo" class="h-9 w-auto" referrerpolicy="no-referrer" />
              <div class="flex flex-col gap-1 items-start">
                <span class="text-sm font-semibold text-neutral-900 dark:text-neutral-100">
                  <span class="text-host-500">Qrati</span> Connect
                </span>
                <span class="text-xs text-neutral-500 dark:text-neutral-400">Elevate your event experience.</span>
              </div>
            </div>

            <div class="flex flex-col items-center sm:items-end gap-2">
              <nav class="flex flex-wrap justify-center gap-x-5 gap-y-2 sm:justify-end" aria-label="Footer navigation">
                <a href="https://qrati.com" target="_blank" rel="noopener noreferrer" class="text-xs text-neutral-500 dark:text-neutral-400 transition-colors hover:text-neutral-900 dark:hover:text-neutral-100">qrati.com</a>
                <a href="https://www.npmjs.com/package/@qratilabs/qrati-connect" target="_blank" rel="noopener noreferrer" class="text-xs text-neutral-500 dark:text-neutral-400 transition-colors hover:text-neutral-900 dark:hover:text-neutral-100">npm</a>
                <a href={`https://github.com/${GITHUB_ORG}`} target="_blank" rel="noopener noreferrer" class="text-xs text-neutral-500 dark:text-neutral-400 transition-colors hover:text-neutral-900 dark:hover:text-neutral-100">GitHub</a>
                <a href="https://qrati.com/pricing" target="_blank" rel="noopener noreferrer" class="text-xs text-neutral-500 dark:text-neutral-400 transition-colors hover:text-neutral-900 dark:hover:text-neutral-100">Pricing</a>
              </nav>
              <p class="text-center text-[0.65rem] text-neutral-400 dark:text-neutral-500 sm:text-left">
                &copy; {new Date().getFullYear()} Qrati Labs. All rights reserved.
              </p>
            </div>
          </div>
        </footer>
      </div>
    </div>

    <script is:inline define:vars={{ QRATI_SCRIPT_URL }}>
      import(QRATI_SCRIPT_URL);
    </script>

    <!-- Theme toggle controller -->
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var btn = document.getElementById('theme-toggle');
        var iconMoon = document.getElementById('icon-moon');
        var iconSun = document.getElementById('icon-sun');
        var labelValue = document.getElementById('theme-label-value');
        var widget = document.getElementById('qrati-widget');

        function applyTheme(isDark) {
          root.classList.toggle('dark', isDark);
          iconMoon.classList.toggle('hidden', isDark);
          iconSun.classList.toggle('hidden', !isDark);
          if (labelValue) labelValue.textContent = isDark ? 'Dark' : 'Light';
          if (widget) widget.setAttribute('theme', isDark ? 'dark' : 'light');
        }

        // Sync UI with the state already set by the FOUC-guard in <head>
        applyTheme(root.classList.contains('dark'));

        btn.addEventListener('click', function () {
          var nowDark = !root.classList.contains('dark');
          localStorage.setItem('qc-theme', nowDark ? 'dark' : 'light');
          applyTheme(nowDark);
        });
      }());
    </script>
  </body>
</html>
